# Postgres connection for Probator (problems, test cases, submissions)
DATABASE_URL="postgres://probator:probator@localhost:5432/probator"

# Piston engine endpoint (self-hosted, runs the student code). No trailing slash.
# Bound to localhost on the host; in production reach it over the internal network.
PISTON_URL="http://localhost:2000"

# Admin panel password (/admin). Leave empty to disable the panel.
ADMIN_PASSWORD=""

# Secret used to sign student session cookies. Set a long random value.
SESSION_SECRET=""

# Discord OAuth2 — student login. Create an app at https://discord.com/developers
# and add the redirect URI <your-origin>/auth/discord/callback. Leave empty to
# disable login (then submissions are anonymous).
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
# Optional: require membership of this Discord server (guild) id to log in.
DISCORD_GUILD_ID=""
