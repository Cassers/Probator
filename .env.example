# Postgres connection for Probator (problems, test cases, submissions)
DATABASE_URL="postgres://probator:probator@localhost:5432/probator"

# Piston engine endpoint (self-hosted, runs the student code). No trailing slash.
# Bound to localhost on the host; in production reach it over the internal network.
PISTON_URL="http://localhost:2000"

# Admin panel password (/admin). Leave empty to disable the panel.
ADMIN_PASSWORD=""
