# Postgres connection for Probator (problems, test cases, submissions)
DATABASE_URL="postgres://probator:probator@localhost:5432/probator"

# Judge0 CE endpoint (self-hosted on OVH via Docker). No trailing slash.
JUDGE0_URL="https://judge0.probator.codes"
# Optional auth header token if you enable AUTHN on Judge0 (X-Auth-Token)
JUDGE0_AUTH_TOKEN=""
